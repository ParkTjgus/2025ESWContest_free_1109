<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        tools:context=".exercise.ExerciseResultActivity">

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="운동 결과"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- 삭제된 LineChart: android:id="@+id/lineChartExerciseProgress" -->

        <TextView
            android:id="@+id/tvTotalExerciseTimeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="총 운동 시간:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/tvResultTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/tvTotalExerciseTimeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            tools:text="1시간 25분 30초"
            app:layout_constraintTop_toTopOf="@id/tvTotalExerciseTimeLabel"
            app:layout_constraintStart_toEndOf="@id/tvTotalExerciseTimeLabel"
            android:layout_marginStart="8dp"/>

        <!-- 삭제된 TextView: android:id="@+id/tvTotalSetsLabel" -->
        <!-- 삭제된 TextView: android:id="@+id/tvTotalSetsValue" -->
        <!-- 삭제된 TextView: android:id="@+id/tvTotalRepsLabel" -->
        <!-- 삭제된 TextView: android:id="@+id/tvTotalRepsValue" -->

        <TextView
            android:id="@+id/tvCompletedExercisesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="완료한 운동 목록"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvTotalExerciseTimeLabel"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExerciseResults"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvCompletedExercisesTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btnCloseResult"
            app:layout_constraintVertical_bias="0.0"
            android:layout_marginBottom="16dp"
            tools:listitem="@layout/item_exercise_result_detail"/>

        <Button
            android:id="@+id/btnCloseResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="확인"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
